# Relativo: em build de produção o bundle resolve para https://navel.pt/api/data.php (evita 301 www→apex em POST).
VITE_API_URL=/api/data.php
# Força build de produção a não usar base localhost vinda de .env.local (send-report / email frota).
VITE_API_BASE_URL=
# Opcional: URL absoluta do log-receiver; se vazio, usa o mesmo host canónico que data.php.
# VITE_LOG_RECEIVER_URL=
