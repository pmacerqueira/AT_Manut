# URL base da API (servidor PHP). Ex: https://www.navel.pt
# NUNCA deixe aqui http://localhost:... e depois faça `npm run build` para deploy — o valor fica
# no JS e em navel.pt o email frota tentaria localhost (CSP / Failed to fetch).
# Deixe vazio em produção. Só preencha em dev ou se o host da API for o mesmo domínio público.
# Endpoints: /api/send-report.php (HTML+PDF), /api/send-email.php (manutenção FPDF), /api/data.php
VITE_API_BASE_URL=

# Obrigatório para enviar emails/relatórios e para flush de logs para log-receiver.php.
# Deve coincidir com ATM_REPORT_AUTH_TOKEN no servidor (fica embutido no bundle em `npm run build`).
# VITE_ATM_REPORT_AUTH_TOKEN=

# ── cPanel / PHP (não são VITE — definir em Environment Variables do hosting) ──
# Obrigatórias para a API em produção (ver servidor-cpanel/api/config.php):
# ATM_DB_USER=  ATM_DB_PASS=  ATM_DB_NAME=
# ATM_JWT_SECRET=   (>= 32 caracteres aleatórios)
# ATM_REPORT_AUTH_TOKEN=   (send-email, send-report, log-receiver, cron HTTP — alinhar com VITE_ATM_REPORT_AUTH_TOKEN no build)
# ATM_TAXONOMY_TOKEN=   (Bearer para taxonomy-nodes.php; alinhar com navel-site documentos-api-config)
# Opcionais: ATM_DB_HOST=localhost  ATM_WEBHOOK_TOKEN=  (ISTOBAL)
# Biblioteca NAVEL (documentos-api.php): mesmo segredo que at_integration_bearer no navel-site
# ATM_NAVEL_DOC_INTEGRATION_TOKEN=
# Opcional: ATM_NAVEL_DOCUMENTOS_API_URL=https://navel.pt/documentos-api.php
# Opcional: ATM_NAVEL_DOC_PROXY_MAX_RESPONSE_BYTES=12582912 (omissão 12 MiB; 0=sem limite)
# Desenvolvimento HTTP local: servidor-cpanel/api/config.local.php.example
