# AT_Manut API — defesa em profundidade (Apache 2.4+ / LiteSpeed LSPHP).
#
# IMPORTANTE: o .htaccess REAL em produção é gerado pelo migrador
# `navel-site/scripts/cpanel-migrate-setenv.mjs`, que adiciona no topo um
# bloco `# BEGIN ATM_ENV` com RewriteRule [E=KEY:VALUE] para cada segredo.
# NÃO é viável usar `SetEnv` neste alojamento (mod_env não carregado;
# diagnosticado 2026-04-24 via probe PHP — ticket CiberConceito #225838).
# NÃO reponhas este ficheiro a partir do repo sem reenvolver o bloco ATM_ENV
# gerado pelo migrador; caso contrário, a API fica sem ligação à BD.
#
# Estratégia em produção:
#   1. `.htaccess` tem `RewriteRule ^ - [E=ATM_*:...]` que injecta os valores
#      em $_SERVER e getenv() intactos, mesmo com caracteres especiais.
#   2. `config.php` lê com `atm_env()` (getenv + $_ENV + $_SERVER + REDIRECT_*).
#   3. O fallback legado `config.deploy-secrets.php` fica arquivado com sufixo
#      `.disabled-TS` (bloqueado pelo FilesMatch abaixo) — pronto para
#      rollback se alguma coisa correr mal.
#
# Desenvolvimento local: usar `config.local.php` com `putenv('ATM_*=...')`.

<IfModule mod_authz_core.c>
  <FilesMatch "^(test-.*|teste-.*|clear-cache)\.php$">
    Require all denied
  </FilesMatch>
  <FilesMatch "^ingest-istobal-retro\.php$">
    Require all denied
  </FilesMatch>
  <FilesMatch "^config\.deploy-secrets\.php(\.disabled-.*)?$">
    Require all denied
  </FilesMatch>
  <FilesMatch "^atm_report_auth\.secret\.php$">
    Require all denied
  </FilesMatch>
  <FilesMatch "^\.htaccess\.bak-.*$">
    Require all denied
  </FilesMatch>
</IfModule>
