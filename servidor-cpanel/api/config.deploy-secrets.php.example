<?php
/**
 * FALLBACK LEGADO — usar só se não for possível usar o método web-native.
 *
 * Actualização 2026-04-24 (ticket CiberConceito #225838):
 *   Neste alojamento (LiteSpeed + LSPHP 8.1) o mod_env NÃO está carregado,
 *   pelo que `SetEnv` é ignorado. O método que funciona é
 *   `RewriteRule ^ - [E=KEY:VALUE]` no .htaccess, gerado pelo script
 *   `navel-site/scripts/cpanel-migrate-setenv.mjs` a partir deste ficheiro
 *   (ou do `.disabled-*` mais recente) e gera também `config.cli-env.php`
 *   para PHP CLI (pipe ISTOBAL).
 *   O ficheiro activo em produção está renomeado para
 *   `config.deploy-secrets.php.disabled-TS` após validação.
 *
 * O ficheiro real nunca é versionado (gitignored) e está bloqueado por HTTP
 * em .htaccess (<FilesMatch "^config\.deploy-secrets\.php(\.disabled-.*)?$">).
 */
declare(strict_types=1);

